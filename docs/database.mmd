erDiagram

  agendamentos {
    uuid id PK
    uuid id_user
    uuid id_teste FK "nullable"
    text status
    timestamptz data_agendamento
    timestamptz created_at
    timestamptz updated_at
  }

  alternativas {
    uuid id PK
    uuid id_questao FK
    int4 posicao
    text texto
    int4 valor
    timestamptz created_at
    timestamptz updated_at
  }

  avaliados {
    uuid id PK
    uuid id_user
    text nome
    date data_nascimento "nullable"
    text genero "nullable"
    timestamptz created_at
    timestamptz updated_at
  }

  contatos {
    uuid id PK
    text whatsapp
    text email
    timestamptz created_at
    timestamptz updated_at
  }

  questionario {
    uuid id PK
    text titulo
    text descricao "nullable"
    int4 versao
    bool ativo
    timestamptz created_at
    timestamptz updated_at
  }

  questoes {
    uuid id PK
    uuid id_questionario FK
    int4 posicao
    text pergunta
    timestamptz created_at
    timestamptz updated_at
  }

  respostas {
    uuid id PK
    uuid id_teste FK
    uuid id_questao FK
    uuid id_alternativa FK
    int4 valor
    timestamptz created_at
  }

  servicos_pacotes {
    uuid id PK
    text pacote
    text descricao "nullable"
    numeric valor
    int4 posicao
    timestamptz created_at
    timestamptz updated_at
  }

  testes {
    uuid id PK
    uuid id_user
    uuid id_avaliado FK
    uuid id_questionario FK
    text status
    int4 pontuacao_total
    text classificacao "nullable"
    text link_pdf "nullable"
    timestamptz started_at "nullable"
    timestamptz finished_at "nullable"
    timestamptz created_at
    timestamptz updated_at
  }

  questionario ||--o{ questoes : possui
  questoes ||--o{ alternativas : possui
  avaliados ||--o{ testes : realiza
  questionario ||--o{ testes : aplicado_em
  testes ||--o{ respostas : possui
  questoes ||--o{ respostas : respondida_em
  alternativas ||--o{ respostas : selecionada_em
  testes ||--o{ agendamentos : agenda