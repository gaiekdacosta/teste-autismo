classDiagram

class AuthUser {
  +uuid id
}

class Agendamento {
  +uuid id
  +uuid id_user
  +uuid id_teste
  +text status
  +timestamptz data_agendamento
  +timestamptz created_at
  +timestamptz updated_at
}

class Alternativa {
  +uuid id
  +uuid id_questao
  +int posicao
  +text texto
  +int valor
  +timestamptz created_at
  +timestamptz updated_at
}

class Avaliado {
  +uuid id
  +uuid id_user
  +text nome
  +date data_nascimento
  +text genero
  +timestamptz created_at
  +timestamptz updated_at
}

class Contato {
  +uuid id
  +text whatsapp
  +text email
  +timestamptz created_at
  +timestamptz updated_at
}

class Questionario {
  +uuid id
  +text titulo
  +text descricao
  +int versao
  +boolean ativo
  +timestamptz created_at
  +timestamptz updated_at
}

class Questao {
  +uuid id
  +uuid id_questionario
  +int posicao
  +text pergunta
  +timestamptz created_at
  +timestamptz updated_at
}

class Resposta {
  +uuid id
  +uuid id_teste
  +uuid id_questao
  +uuid id_alternativa
  +int valor
  +timestamptz created_at
}

class ServicoPacote {
  +uuid id
  +text pacote
  +text descricao
  +numeric valor
  +int posicao
  +timestamptz created_at
  +timestamptz updated_at
}

class Teste {
  +uuid id
  +uuid id_user
  +uuid id_avaliado
  +uuid id_questionario
  +text status
  +int pontuacao_total
  +text classificacao
  +timestamptz started_at
  +timestamptz finished_at
  +timestamptz created_at
  +timestamptz updated_at
}

